)
->
str
:
"""Search the web."""
return
f
"web results for
{
query
}
"
class
ResearchFindings
(
BaseModel
):
"""Structured findings from a research task."""
summary
:
str
=
Field
(
description
=
"Summary of findings"
)
confidence
:
float
=
Field
(
description
=
