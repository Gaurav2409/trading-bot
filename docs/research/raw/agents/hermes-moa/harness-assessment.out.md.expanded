import
StopAtTools
@function_tool
def
get_weather
(
city
:
str
)
->
str
:
"""Returns weather info for the specified city."""
return
f
"The weather in
{
city
}
is sunny"
@function_tool
def
sum_numbers
(
a
:
int
,
b
:
int
)
->
int
:
"""Adds two numbers."""
return
a
+
b
agent
=
Agent
(
name
=
"Stop At Stock Agent"
,
instructions
=
"Get weather or sum numbers."
,
