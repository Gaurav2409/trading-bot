[
int
,
int
]:
previous
=
previous
or
0
# This will return the previous value to the caller, saving
# 2 * number to the checkpoint, which will be used in the next invocation
# for the `previous` parameter.
return
entrypoint
.
final
(
value
=
previous
,
save
=
2
*
number
)
