class
FactCheck
(dspy.Module):
def
__init__
(self):
self.find = dspy.
ChainOfThought
(
"article -> claims: list[str]"
)
self.verify = dspy.
ChainOfThought
(
"claim, source -> verdict"
)
def
forward
(self, article):
found = self.find(article=article)
return
[
self.verify(claim=c, source=article)
for
c
in
found.claims]
