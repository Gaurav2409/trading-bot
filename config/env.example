# Example environment configuration
# Copy to .env and fill in your values — never commit .env

# --- Zerodha Kite Connect (India) ---
KITE_API_KEY=
KITE_API_SECRET=
KITE_TOTP_SECRET=          # For TOTP-based login automation

# --- Angel One SmartAPI (India) ---
ANGEL_API_KEY=
ANGEL_CLIENT_CODE=
ANGEL_MPIN=
ANGEL_TOTP_SECRET=

# --- IBKR (US / Europe) ---
IBKR_HOST=127.0.0.1
IBKR_PORT=7497             # 7497 = paper trading, 7496 = live
IBKR_CLIENT_ID=1

# --- Market Data ---
POLYGON_API_KEY=
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets   # paper; change for live
IEX_API_TOKEN=

# --- LLM (for agent reasoning) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- App ---
LOG_LEVEL=INFO
ENVIRONMENT=development    # development | staging | production
DEFAULT_MARKET=india       # india | us | europe
DEFAULT_MODE=paper         # paper | live
